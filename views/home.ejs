<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>MyDrive - Home</title>
    <style>
        /* Setting the default font to Inter and making text slightly bigger */
        body {
            font-family: 'Inter', sans-serif;
        }
        /* Ensure normal text is slightly larger as requested */
        .body-text-lg {
            font-size: 1.125rem; /* Equivalent to Tailwind's text-lg */
            line-height: 1.75rem; /* Equivalent to Tailwind's leading-7 */
        }
    </style>
</head>
<!-- Body uses light background (zinc-100) and dark gray text -->
<body class="min-h-screen bg-zinc-100 text-gray-800 body-text-lg">
    <!-- 1. Header - Fixed White Background with Border -->
    <header class="border-b border-gray-300 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex justify-between items-center">
            <!-- Logo: Text color is dark indigo (text-indigo-800) -->
            <div class="text-3xl font-extrabold text-indigo-800 tracking-tight">
                MyDrive
            </div>
            <!-- Navigation Links -->
            <nav class="space-x-8 text-lg font-medium">
                <a href="#" class="text-indigo-800 border-b-2 border-indigo-800 pb-1 transition-colors">Home</a>
                <a href="#" class="text-gray-700 hover:text-indigo-800 transition-colors">About</a>
                <a href="#" class="text-gray-700 hover:text-indigo-800 transition-colors">Features</a>
                <a href="#" class="px-4 py-2 border border-indigo-800 text-indigo-800 rounded-lg hover:bg-indigo-50 transition-all">Sign In</a>
            </nav>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <!-- 2. Hero Section - White Background with Border -->
        <section class="text-center py-20 mb-16 bg-white rounded-xl border border-gray-300">
            <!-- Heading color is dark indigo (text-indigo-800) -->
            <h1 class="text-6xl font-extrabold text-indigo-800 tracking-tight">
                Welcome to MyDrive :)
            </h1>
            <!-- Normal text color is dark gray (text-gray-800) -->
            <p class="mt-4 text-xl text-gray-800">
                Your secure and collaborative cloud storage solution.
            </p>
        </section>

        <!-- 3. Dual Part Section (Features & Sign In) -->
        <section class="flex flex-col md:flex-row gap-8">
            <!-- Left Part: Features - White Background with Border -->
            <div class="md:w-1/2 p-8 bg-white rounded-xl border border-gray-300">
                <h2 class="text-3xl font-bold mb-6 text-indigo-800 border-b border-gray-300 pb-2">
                    MyDrive
                </h2>
                <ul class="space-y-4">
                    <li class="flex items-start">
                        <span class="text-indigo-800 mr-3 text-2xl">✨</span>
                        <p class="text-gray-800">
                            **Secure File Encryption:** Keep your data safe with industry-leading encryption.
                        </p>
                    </li>
                    <li class="flex items-start">
                        <span class="text-indigo-800 mr-3 text-2xl">🤝</span>
                        <p class="text-gray-800">
                            **Real-time Collaboration:** Share and edit documents with your team instantly.
                        </p>
                    </li>
                    <li class="flex items-start">
                        <span class="text-indigo-800 mr-3 text-2xl">☁️</span>
                        <p class="text-gray-800">
                            **Unlimited Storage:** Never worry about running out of space again.
                        </p>
                    </li>
                    <li class="flex items-start">
                        <span class="text-indigo-800 mr-3 text-2xl">📱</span>
                        <p class="text-gray-800">
                            **Cross-Platform Access:** Use MyDrive on any device, anywhere.
                        </p>
                    </li>
                    <li class="flex items-start">
                        <span class="text-indigo-800 mr-3 text-2xl">⏱️</span>
                        <p class="text-gray-800">
                            **Version History:** Restore previous file versions with ease.
                        </p>
                    </li>
                </ul>
            </div>

            <!-- Right Part: Sign In Form - White Background with Border -->
            <div class="md:w-1/2 p-8 bg-white rounded-xl border border-gray-300">
                <h3 class="text-3xl font-bold text-indigo-800 mb-6 text-center border-b border-gray-300 pb-2">
                    Sign In
                </h3>
                <form class="space-y-6">
                    <div>
                        <label for="email" class="block text-lg font-medium text-gray-700 mb-1">Email address</label>
                        <input type="email" id="email" name="email" required
                            class="w-full px-4 py-3 border border-gray-400 text-gray-800 rounded-lg focus:ring-indigo-800 focus:border-indigo-800 transition-colors"
                            placeholder="you@example.com">
                    </div>
                    <div>
                        <label for="password" class="block text-lg font-medium text-gray-700 mb-1">Password</label>
                        <input type="password" id="password" name="password" required
                            class="w-full px-4 py-3 border border-gray-400 text-gray-800 rounded-lg focus:ring-indigo-800 focus:border-indigo-800 transition-colors"
                            placeholder="Enter your password">
                    </div>
                    <!-- Submit button uses the dark indigo background color -->
                    <button type="submit" 
                        class="w-full py-3 px-4 border border-transparent rounded-lg text-lg font-medium text-white bg-indigo-800 hover:bg-indigo-900 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-800 transition-colors">
                        Submit
                    </button>
                </form>

                <div class="mt-6 text-center space-y-2 text-lg">
                    <a href="#" class="block text-indigo-800 hover:underline">
                        Forgot Password?
                    </a>
                    <a href="#" class="block text-indigo-800 hover:underline">
                        Sign Up for free to get started
                    </a>
                </div>
            </div>
        </section>
    </main>

    <!-- 4. Footer - White Background with Border -->
    <footer class="py-6 bg-white border-t border-gray-300 mt-8">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-sm text-gray-600">
            &copy; Copyright 2025 Mitesh Prajapati
        </div>
    </footer>
</body>
</html>